const fs = require('fs');
const projects = require('./src/assets/projects.json');

const staticUrls = [
  { loc: 'https://madain.sa/', priority: 1.0, changefreq: 'weekly' },
  { loc: 'https://madain.sa/home', priority: 0.9, changefreq: 'weekly' },
  { loc: 'https://madain.sa/about', priority: 0.8, changefreq: 'monthly' },
  { loc: 'https://madain.sa/services', priority: 0.8, changefreq: 'monthly' },
  { loc: 'https://madain.sa/projects', priority: 0.9, changefreq: 'weekly' },
  { loc: 'https://madain.sa/contact', priority: 0.7, changefreq: 'monthly' },
];

let xml = '<?xml version="1.0" encoding="UTF-8"?>\n';
xml += '<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">\n';

// الصفحات الستاتيك
staticUrls.forEach((page) => {
  xml += `  <url>\n`;
  xml += `    <loc>${page.loc}</loc>\n`;
  xml += `    <changefreq>${page.changefreq}</changefreq>\n`;
  xml += `    <priority>${page.priority}</priority>\n`;
  xml += `  </url>\n`;
});

// الصفحات الديناميك
projects.forEach((project) => {
  xml += `  <url>\n`;
  xml += `    <loc>https://madain.sa/${project.slug}</loc>\n`;
  xml += `    <changefreq>monthly</changefreq>\n`;
  xml += `    <priority>0.8</priority>\n`;
  xml += `  </url>\n`;
});

xml += '</urlset>';

fs.writeFileSync('dist/sitemap.xml', xml);
console.log('Sitemap generated successfully!');